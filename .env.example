# Gere estes valores com: docker compose run --rm api python scripts/generate_auth_credentials.py
AUTH_COOKIE_SECURE=false
AUTH_OPERATOR_EMAIL=operator@example.com
AUTH_PASSWORD_HASH=
AUTH_SECRET_KEY=
AUTH_SESSION_MINUTES=30
AUTH_TOTP_SECRET=
PUBLIC_WEB_URL=http://localhost:3000
USER_INVITATION_HOURS=48
# Para envio automático por e-mail:
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true
# Para envio automático pelo Telegram (BotFather):
TELEGRAM_BOT_TOKEN=
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true
DATABASE_URL=postgresql+psycopg://tradebot:change-me@db:5432/tradebot
POSTGRES_DB=tradebot
POSTGRES_PASSWORD=change-me
POSTGRES_USER=tradebot
RESEARCH_AUTOMATION_ENABLED=false
RESEARCH_EVALUATION_INTERVAL_SECONDS=3600
RESEARCH_DATASET_LIMIT=3900
RESEARCH_HORIZON=4
RESEARCH_TRAIN_RATIO=0.8
RESEARCH_MINIMUM_NEW_CANDLES=0
RESEARCH_PROMOTE_QUALIFIED=false
